---
import ServiceCard from './ServiceCard.astro';

const services = [
  {
    icon: '🔧',
    title: 'Achsvermessung',
    description: 'Professionelle Achsvermessung für optimalen Geradeauslauf und gleichmäßigen Reifenverschleiß'
  },
  {
    icon: '🔍',
    title: 'Fahrzeugdiagnose',
    description: 'Moderne Diagnosegeräte für alle Fahrzeugmarken zur schnellen Fehlererkennung'
  },
  {
    icon: '✅',
    title: 'Inspektion',
    description: 'Regelmäßige Inspektionen nach Herstellervorgaben für die Sicherheit Ihres Fahrzeugs'
  },
  {
    icon: '❄️',
    title: 'Klimaservice',
    description: 'Wartung und Reparatur Ihrer Klimaanlage für angenehmes Fahren das ganze Jahr'
  },
  {
    icon: '🛞',
    title: 'Reifenservice',
    description: 'Reifenwechsel, Einlagerung und Auswuchtung für sicheres Fahren'
  },
  {
    icon: '🚗',
    title: 'Unfallservice',
    description: 'Professionelle Unfallreparaturen und Unterstützung bei der Schadensabwicklung'
  },
  {
    icon: '🚚',
    title: 'Anhängerreparatur',
    description: 'Reparatur und Wartung von ungebremsten Anhängern bis 750kg'
  },
  {
    icon: '📋',
    title: 'AU & HU',
    description: 'Hauptuntersuchung jeden Mittwoch und Donnerstag nach Terminvereinbarung'
  }
];
---

<section id="leistungen" class="py-16 lg:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-800 mb-4">
        Unsere Serviceleistungen im Überblick
      </h2>
      <p class="text-lg lg:text-xl text-gray-600 max-w-3xl mx-auto">
        Professionelle Werkstattleistungen für alle Fahrzeugmarken
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
      {services.map(service => (
        <ServiceCard
          icon={service.icon}
          title={service.title}
          description={service.description}
        />
      ))}
    </div>
  </div>
</section>
